{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-x64",
      "displayName": "Linux x64",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux/x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x64 Debug",
      "inherits": "linux-x64"
    },
    {
      "name": "linux-arm64",
      "displayName": "Linux arm64",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux/arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VCPKG_TARGET_TRIPLET": "arm64-linux"
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/windows/x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "windows-arm64",
      "displayName": "Windows arm64",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/windows/arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "arm64-windows"
      }
    },
    {
      "name": "macos-x64",
      "displayName": "macOS x64",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/macos/x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-osx"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/macos/arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-x64",
      "configurePreset": "linux-x64"
    },
    {
      "name": "linux-x64-debug",
      "configurePreset": "linux-x64-debug"
    },
    {
      "name": "linux-arm64",
      "configurePreset": "linux-arm64"
    },
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64"
    },
    {
      "name": "windows-arm64",
      "configurePreset": "windows-arm64"
    },
    {
      "name": "macos-x64",
      "configurePreset": "macos-x64"
    },
    {
      "name": "macos-arm64",
      "configurePreset": "macos-arm64"
    }
  ]
}
